{
  "name": "electron-assessment",
  "version": "1.0.0",
  "description": "Electron Desktop Dashboard Application",
  "main": "src/js/main.js",
  "scripts": {
    "electron:serve": "electron .",
    "electron:build": "electron-builder",
    "test": "node --test tests/**/*.test.js"
  },
  "keywords": [
    "electron",
    "dashboard",
    "desktop"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bootstrap": "^4.6.2",
    "d3": "^7.9.0",
    "pouchdb": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0"
  },
  "build": {
    "appId": "com.example.electron-assessment",
    "productName": "Electron Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
